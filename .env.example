# =============================================================
# ACCIDENTALIDAD JMC - Variables de Entorno
# Copiar a .env para desarrollo local (NO subir .env al repo)
# En producción configurar en Azure App Service Settings
# =============================================================

APP_ENV=development
APP_NAME=Accidentalidad JMC
APP_VERSION=1.0.0
SECRET_KEY=cambia-esto-en-produccion-minimo32chars!
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Base de datos (SQLite local — en Azure usar /home/data/)
DB_PATH=/home/data/accidentalidad.db

# CORS — agregar URL de Azure cuando se despliegue
ALLOWED_ORIGINS=http://localhost:8000

# Azure Blob Storage (configurar cuando esté listo)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=accidentalidad-archivos

# Ruta al MasterData SAP
MASTERDATA_PATH=data/masterdata.xlsx
